# --- Críticas: la app no arranca si faltan (config/env.ts) ---

# Cadena de conexión a PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/mydb"

# Secretos de firma (usa valores largos y aleatorios, distintos entre sí)
JWT_KEY="change-me"
JWT_KEY_REFRESH="change-me-too"
COOKIE_KEY="change-me-as-well"

# --- Opcionales: tienen default en config/env.ts ---

# PORT=3000
# CORS_ORIGIN=http://localhost:5173

# "production" activa cookies con secure: true
# ENVIRONMENT=production

# Vidas de los tokens, en segundos. El maxAge de las cookies se deriva de aquí.
# ACCESS_TOKEN_TTL_S=900        # 15 minutos
# REFRESH_TOKEN_TTL_S=604800    # 7 días
